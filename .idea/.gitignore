# ============================
# Python 3.13 – .gitignore
# ============================

# --- Byte-compiled / optimized files ---
__pycache__/
*.py[cod]
*$py.class

# --- C extensions ---
*.so

# --- Distribution / packaging ---
build/
dist/
pip-wheel-metadata/
*.egg-info/
*.egg

# --- Virtual environments ---
# Detecta entornos creados por:
# - python3 -m venv .venv
# - uv venv
# - virtualenv
.venv/
venv/
env/
ENV/

# --- PyInstaller ---
*.manifest
*.spec

# --- Installer logs ---
pip-log.txt
pip-delete-this-directory.txt

# --- Unit test / coverage reports ---
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
pytest_cache/
coverage.xml

# --- Jupyter Notebook ---
.ipynb_checkpoints/
*.ipynb~

# --- PyCharm ---
.idea/
*.iml

# --- VS Code ---
.vscode/
# Excepta configuraciones compartibles (opcional):
# !.vscode/settings.json
# !.vscode/extensions.json

# --- macOS / Linux / Windows OS files ---
.DS_Store
Thumbs.db

# --- Local config ---
*.local
*.env
.env.*
.envrc

# --- MyPy / type checkers ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
pytype/

# --- Ruff / linters ---
ruff_cache/

# --- Logs ---
*.log
logs/

# --- SQLite / app data ---
*.sqlite3
*.db
instance/

# --- Temporary files ---
tmp/
temp/
*.tmp
